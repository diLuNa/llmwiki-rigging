// wrinkle-stress-vector.vex
// Art-Directed Wrinkle System — Stress Vector Computation
// Source: Cutler et al., Computers & Graphics 2007 (§5, Fig. 6)
//
// Per-point Geometry Wrangle.
// For each vertex, computes the 16-component stress vector:
//   S = <l_1...8, c_1...8>
//   l_i = world-space length of edge to i-th neighbour (up to 8)
//   c_i = cos(angle) between adjacent edges at this vertex
//
// Run on EACH pose (rest, reference poses, animation frames).
// Store stress vectors as point float arrays for use in
// wrinkle-proximity-metric.vex.
//
// Inputs:  @P (point positions, current pose)
// Outputs: @wrinkle_stress (float[16]) — stress vector per vertex
//          @wrinkle_valence (int)       — actual number of neighbours used

int    n_max   = 8;   // paper uses 8 nearest neighbours
int    n_total = n_max * 2;   // 8 lengths + 8 cosines = 16 components

float sv[] = array();
resize(sv, n_total);
for (int k = 0; k < n_total; k++) sv[k] = 0.0;

// ── gather up to 8 neighbours ─────────────────────────────────────────────
int nbcount = neighbourcount(0, @ptnum);
int n_used  = min(nbcount, n_max);

vector edges[];
resize(edges, n_used);

for (int i = 0; i < n_used; i++) {
    int nb = neighbour(0, @ptnum, i);
    edges[i] = point(0, "P", nb) - @P;
}

// ── l_i: edge lengths (components 0..n_used-1) ───────────────────────────
for (int i = 0; i < n_used; i++) {
    sv[i] = length(edges[i]);
}

// ── c_i: cosines of angles between adjacent edges (components 8..8+n_used-1)
// angle between edge i and edge (i+1) % n_used
for (int i = 0; i < n_used; i++) {
    int next = (i + 1) % n_used;
    float len_i    = sv[i];
    float len_next = sv[next];
    if (len_i > 1e-8 && len_next > 1e-8) {
        sv[8 + i] = dot(edges[i], edges[next]) / (len_i * len_next);
    } else {
        sv[8 + i] = 0.0;
    }
}

@wrinkle_stress  = sv;
@wrinkle_valence = n_used;

// ── Usage notes ──────────────────────────────────────────────────────────
//
// Run this wrangle THREE times:
//   1. On the REST pose mesh  → store as @rest_stress   on a rest geo
//   2. On each REFERENCE POSE → store as @ref_stress_k  (one attrib per ref)
//   3. On each ANIMATION FRAME → store as @wrinkle_stress (live)
//
// The rest stress defines the "zero" baseline in Eq. 1.
// Reference pose stresses define the targets.
//
// Recommended workflow in Houdini:
//   rest_geo    → wrangle (stress) → merge into a point cloud as "rest_stress"
//   ref_pose_0  → wrangle (stress) → promote to "ref_stress_0"
//   ...
//   anim_frame  → wrangle (stress) → feed into wrinkle-proximity-metric.vex
