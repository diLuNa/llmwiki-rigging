// bbw-cotan-laplacian.vex
// Bounded Biharmonic Weights — Cotangent Laplacian Assembly
// Source: Jacobson et al., SIGGRAPH 2011 (§3, Appendix A)
//
// Per-primitive Geometry Wrangle on a TRIANGLE mesh.
// For each triangle, computes the three cotan half-weights and stores
// sparse (row, col, val) triplets on the detail for Python assembly.
//
// Inputs:  @P (point positions)
// Outputs: detail int arrays  L_row[], L_col[]
//          detail float array L_val[]
//
// The cotangent weight for edge (i,j) contributed by this triangle
// is 0.5 * cot(angle opposite to that edge).
//
// Full Laplacian entry: L[i,j] = -sum of half-weights from adjacent triangles
//                       L[i,i] = -sum_j L[i,j]
//
// Run this wrangle once; Python assembles the full sparse L matrix.
//
// Usage:
//   Connect your rest-pose triangle mesh.
//   After running, call the Python solve (see bbw-solve.py comment below).

// ── vertex positions ──────────────────────────────────────────────────────
int pts[] = primpoints(0, @primnum);
if (len(pts) != 3) return;   // triangles only

vector p0 = point(0, "P", pts[0]);
vector p1 = point(0, "P", pts[1]);
vector p2 = point(0, "P", pts[2]);

// ── edge vectors from each vertex ─────────────────────────────────────────
// angle at p0, opposite edge (p1,p2)
vector e01 = p1 - p0;  vector e02 = p2 - p0;
// angle at p1, opposite edge (p0,p2)
vector e10 = p0 - p1;  vector e12 = p2 - p1;
// angle at p2, opposite edge (p0,p1)
vector e20 = p0 - p2;  vector e21 = p1 - p2;

// ── cotangents via cot(theta) = dot / |cross| ─────────────────────────────
float cross_len0 = length(cross(e01, e02));
float cross_len1 = length(cross(e10, e12));
float cross_len2 = length(cross(e20, e21));

float EPS = 1e-10;
float cot0 = (cross_len0 > EPS) ? dot(e01, e02) / cross_len0 : 0.0;
float cot1 = (cross_len1 > EPS) ? dot(e10, e12) / cross_len1 : 0.0;
float cot2 = (cross_len2 > EPS) ? dot(e20, e21) / cross_len2 : 0.0;

// ── half-weights (each edge gets contributions from two triangles) ─────────
// edge (p1,p2): half-weight = 0.5 * cot0   (row pts[1], col pts[2] and vice versa)
// edge (p0,p2): half-weight = 0.5 * cot1
// edge (p0,p1): half-weight = 0.5 * cot2

int rows[]  = array(pts[1], pts[2], pts[0], pts[2], pts[0], pts[1]);
int cols[]  = array(pts[2], pts[1], pts[2], pts[0], pts[1], pts[0]);
float vals[] = array(0.5*cot0, 0.5*cot0,
                     0.5*cot1, 0.5*cot1,
                     0.5*cot2, 0.5*cot2);

// ── append to detail arrays (thread-unsafe — run single-threaded or merge) ─
// Single-threaded: set "Multi-threading mode" = "Disabled" on this wrangle.
int base = len(detail(0, "L_row", {}));
resize(detail(0, "L_row",  {}), base + 6);
resize(detail(0, "L_col",  {}), base + 6);
resize(detail(0, "L_val",  {}), base + 6);

for (int k = 0; k < 6; k++) {
    setdetailattrib(0, "L_row", base + k, rows[k],  "append");
    setdetailattrib(0, "L_col", base + k, cols[k],  "append");
    setdetailattrib(0, "L_val", base + k, -vals[k], "append"); // negative = off-diagonal L
}

// ─────────────────────────────────────────────────────────────────────────
// PYTHON SOLVE (run in a Python SOP after this wrangle)
// ─────────────────────────────────────────────────────────────────────────
//
// import numpy as np, scipy.sparse as sp, scipy.sparse.linalg as spla
