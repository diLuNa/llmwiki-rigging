//   K = np.zeros((3*n, 3*n))
//   for i in range(n):
//       for j in range(n):
//           rij = centers[j] - centers[i]
//           Kij = K_eps(rij, epsilons[i], ba)
//           K[3*i:3*i+3, 3*j:3*j+3] = Kij
//
