// bbw-mass-matrix.vex
// Bounded Biharmonic Weights — Lumped Mass Matrix
// Source: Jacobson et al., SIGGRAPH 2011 (§3, Appendix A)
//
// Per-point Geometry Wrangle on a TRIANGLE mesh.
// Computes the lumped (diagonal) mass for each vertex:
//   M_i = (1/3) * sum of areas of triangles incident to vertex i
//
// This is the standard lumped mass matrix entry used in
// the biharmonic system  H = L^T M^{-1} L.
//
// Inputs:  @P (point positions)
// Outputs: point float @bbw_area  (M_i per vertex)
//
// Run BEFORE the Python solve in bbw-cotan-laplacian.vex.
// Run this wrangle on the REST mesh.

@bbw_area = 0.0;

// Accumulate 1/3 of each incident triangle's area
int prims[] = pointprims(0, @ptnum);

for (int k = 0; k < len(prims); k++) {
    int prim = prims[k];
    int pts[] = primpoints(0, prim);
    if (len(pts) != 3) continue;

    vector p0 = point(0, "P", pts[0]);
    vector p1 = point(0, "P", pts[1]);
    vector p2 = point(0, "P", pts[2]);

    float tri_area = 0.5 * length(cross(p1 - p0, p2 - p0));
    @bbw_area += tri_area / 3.0;
}

// Guard against degenerate isolated vertices
if (@bbw_area < 1e-12) @bbw_area = 1e-12;

// ── Example usage ─────────────────────────────────────────────────────────
//
// After this wrangle, each point has @bbw_area = M_i.
// In Python:
//   mass = np.array([pt.attribValue("bbw_area") for pt in geo.points()])
//   Minv = scipy.sparse.diags(1.0 / mass)
//   H    = L.T @ Minv @ L    # biharmonic energy Hessian
//
// Typical values: M_i ≈ local triangle area / 3 ≈ O(edge_length^2 / 6)
// For uniform meshes, M is proportional to identity and can be dropped.
