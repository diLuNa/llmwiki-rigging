// blendshape-nlls-faceit.vex
// FACEIT-style 2D landmark-driven blendshape weight solving (NLLS / LM).
// Source: Díaz Barros et al., FACEIT (~2020)
//
//   min_alpha  sum_j ‖L_j - Pi(V_j(alpha), pose)‖²  +  mu * ‖∇alpha‖²
//
// where L_j are 2D landmark positions from the video frame,
// Pi is the perspective camera projection, V_j(alpha) is the 3D position
// of landmark vertex j on the blendshape-driven mesh, and the second term
// enforces temporal smoothness.
//
// VEX handles: camera projection of 3D mesh vertices → 2D screen coords.
// Python handles: NLLS residual + Levenberg-Marquardt optimisation.
//
// USAGE (Point Wrangle — projects 3D mesh positions through camera):
//   Reads camera transform matrix "cam_xform" (detail, float[16] row-major).
//   Reads intrinsics "cam_K" (detail, float[9]: fx,0,cx, 0,fy,cy, 0,0,1).
//   Writes projected UV positions to "uv_proj" point attribute.

// --- Read camera intrinsics and extrinsics from detail ---
matrix cam_xform = detail(0, "cam_xform");  // world-to-camera 4x4
float  K[]       = detail(0, "cam_K");      // 3x3 intrinsic (row-major, 9 floats)

float fx = K[0], fy = K[4];
float cx = K[2], cy = K[5];

// --- Transform point to camera space ---
vector P_world  = @P;
vector4 Ph      = set(P_world.x, P_world.y, P_world.z, 1.0);
vector4 P_cam4  = Ph * cam_xform;
vector  P_cam   = set(P_cam4.x, P_cam4.y, P_cam4.z);

// --- Perspective divide ---
float  u_ndc = P_cam.x / max(P_cam.z, 1e-6);
float  v_ndc = P_cam.y / max(P_cam.z, 1e-6);

// --- Apply intrinsics: NDC → pixel ---
float u_px = fx * u_ndc + cx;
float v_px = fy * v_ndc + cy;

v@uv_proj = set(u_px, v_px, 0.0);

// -------------------------------------------------------
// Python NLLS Solver (run in a Python node)
// -------------------------------------------------------
// ```python
