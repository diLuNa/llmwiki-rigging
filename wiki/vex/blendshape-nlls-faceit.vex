// lmk_idx   = list(geo.attribValue("lmk_indices")) # vertex indices
//
// # blendshape target positions — packed float array
// shapes_flat = np.array(geo.attribValue("shape_pos"))
// N_verts     = shapes_flat.size // (N_shapes * 3)
// shapes      = shapes_flat.reshape(N_shapes, N_verts, 3)
//
