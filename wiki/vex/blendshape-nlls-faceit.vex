// K           = np.array(geo.attribValue("cam_K")).reshape(3, 3)
// R_cam       = np.array(geo.attribValue("cam_R")).reshape(3, 3)  # rotation
// t_cam       = np.array(geo.attribValue("cam_t"))                # translation
