// F = np.zeros((N, K))
// for i, pt in enumerate(geo.points()):
//     F[i, :] = pt.attribValue("target_val")
//
// # Regularize for numerical stability (Tikhonov)
// reg = 1e-6
// Phi_reg = Phi + reg * np.eye(N)
//
// # Solve: Φ λ = F  (solve column by column, or batch)
// Lambdas = np.linalg.solve(Phi_reg, F)   # shape (N, K)
//
// # Write coefficients back to points
// geo.addAttrib(hou.attribType.Point, "lambda_vec", [0.0] * K)
// for i, pt in enumerate(geo.points()):
//     pt.setAttribValue("lambda_vec", Lambdas[i, :].tolist())
//
// print(f"RBF solve complete: {N} centers, {K} outputs")
